{
  "manifestVersion": 5,
  "id": "com.danharris.clientreelbuilder",
  "name": "Client Reel Builder",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "clientReelBuilderPanel",
      "label": {
        "default": "Client Reel Builder"
      },
      "minimumSize": { "width": 320, "height": 480 },
      "preferredDockedSize": { "width": 380, "height": 720 },
      "preferredFloatingSize": { "width": 420, "height": 760 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "allowCodeGenerationFromStrings": false
  }
}
